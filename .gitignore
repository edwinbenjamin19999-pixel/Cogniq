# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Cryptographic material — never commit
*.p12
*.pem
*.pfx
*.key

# Local environment files (never commit real secrets)
.env
.env.development
!.env.example
# .env.production is committed intentionally: it holds only public,
# build-time frontend config (Supabase URL + anon key, Stripe pk_ token),
# which Vite inlines into the client bundle anyway. No real secrets here.
!.env.production
